PORT=5000
NODE_ENV=production
MONDAY_API_TOKEN=
MONDAY_WORKORDERS_BOARD_ID=
MONDAY_DEALS_BOARD_ID=

# LLM provider: "openai" (default), "groq", or "openrouter".
# Groq and OpenRouter both expose OpenAI-compatible endpoints, so the same
# ChatOpenAI client is reused with a different baseURL/key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# Optional model override (sensible per-provider default used if blank)
LLM_MODEL=

FRONTEND_ORIGIN=http://localhost:3000
CACHE_TTL_SECONDS=300
